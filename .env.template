# ============================================================
# LOGISTEIA - PLANTILLA DE VARIABLES DE ENTORNO
# ============================================================
# Copia este archivo a .env y rellena los valores reales
# NO COMMITEAR .env - Solo mantener .env.template en git
# ============================================================

# ============================================================
# BASE DE DATOS
# ============================================================
DB_HOST=db
DB_PORT=3306
DB_NAME=Logisteia
DB_USER=logisteia_user
DB_PASS=cambiar_contraseña_segura_aqui
DB_USE_SSL=false

# Pool de conexiones (valores de producción)
DB_POOL_MAX=20
DB_POOL_MIN=5

# JPA/Hibernate
# Desarrollo: update | Producción: validate
JPA_DDL_AUTO=validate

# ============================================================
# SERVIDOR SPRING BOOT
# ============================================================
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=production

# ============================================================
# SEGURIDAD - JWT
# ============================================================
# Generar un secret seguro con: openssl rand -base64 32
JWT_SECRET=cambiar_por_secret_seguro_minimo_256_bits_base64
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ============================================================
# CORS
# ============================================================
# En producción: usar dominio real, NO localhost
CORS_ALLOWED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com

# ============================================================
# LOGGING
# ============================================================
# Desarrollo: DEBUG | Producción: WARN
LOG_LEVEL=WARN
LOG_LOGISTEIA_LEVEL=INFO
LOG_FILE=/var/log/logisteia/app.log

# ============================================================
# ACTUATOR & MONITOREO
# ============================================================
# Health endpoints para Docker health checks
ACTUATOR_ENDPOINTS=health,info,metrics

# ============================================================
# DOCKER
# ============================================================
COMPOSE_PROJECT_NAME=logisteia
COMPOSE_FILE=compose.yml

# ============================================================
# CERTIFICADOS SSL (OPCIONAL)
# ============================================================
# Descomentar solo si tienes certificados SSL configurados
# SSL_KEYSTORE_PATH=/etc/nginx/ssl/keystore.jks
# SSL_KEYSTORE_PASSWORD=tu_keystore_password
# SSL_KEY_ALIAS=tu_key_alias
